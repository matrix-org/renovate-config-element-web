{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default preset for use with the Element Web stack of projects",
  "extends": [
      "config:base",
      "packages:linters",
      "packages:postcss",
      "packages:stylelint",
      "packages:eslint",
      "packages:vite",
      "packages:jsUnitTest",
      "group:definitelyTyped",
      "group:monorepos",
      "group:recommended",
      "npm:unpublishSafe",
      "helpers:disableTypesNodeMajor",
      ":dependencyDashboardApproval"
  ],
  "labels": ["T-Task", "Dependencies"],
  "semanticCommits": "disabled",
  "lockFileMaintenance": { "enabled": false },
  "packageRules": [{
      "groupName": "{{manager}} non-major dependencies",
      "groupSlug": "{{manager}}-minor-patch",
      "matchPackagePatterns": [
          "*"
      ],
      "matchUpdateTypes": [
          "minor",
          "patch"
      ]
  }, {
      "matchFiles": ["package.json"],
      "rangeStrategy": "update-lockfile"
  }, {
      "groupName": "pnpm",
      "matchDepNames": "pnpm"
  }, {
      "groupName": "electron",
      "matchDepNames": [
        "/electron/",
        "node-abi"
      ]
  }, {
      "groupName": "playwright",
      "matchDepNames": "/playwright/"
  }, {
      "groupName": "vite",
      "matchDepNames": "/vite/"
  }, {
      "groupName": "css",
      "matchDepNames": [
        "@types/css-font-loading-module{/,}**",
        "mini-css-extract-plugin{/,}**",
        "postcss{/,}**"
      ]
  }, {
      "groupName": "babel",
      "matchDepNames": "/babel/"
  }, {
      "groupName": "react",
      "matchDepNames": "/react/"
  }, {
      "groupName": "jest",
      "matchDepNames": [
        "jest{/,}**",
        "@types/jest",
        "babel-jest",
        "@casualbot/jest-sonar-reporter"
      ]
  }, {
      "groupName": "electron-builder",
      "matchDepNames": [
        "electron-builder",
        "electron-builder-squirrel-windows",
        "app-builder-lib"
      ]
  }, {
      "groupName": "axe",
      "matchDepNames": [
        "axe-core"
      ]
  }, {
      "groupName": "docker",
      "matchDepNames": [
        "docker{/,}**"
      ]
  }, {
    "groupName": "storybook",
    "matchDepNames": ["/storybook/"]
  }, {
      "groupName": "vector-im",
      "matchDepNames": [
        "@vector-im/{/,}**"
      ]
  }, {
      "groupName": "matrix-org",
      "matchDepNames": [
        "@matrix-org/{/,}**",
        "matrix-{/,}**"
      ]
  }, {
      "groupName": "matrix-events-sdk",
      "matchDepNames": [
        "matrix-events-sdk"
      ]
  }, {
    "groupName": "Element Call",
    "matchDepNames": [
      "@element-hq/element-call-embedded"
    ]
  }, {
      "groupName": "typescript",
      "matchDepNames": [
        "typescript",
        "/typedoc/"
      ]
  }, {
      "groupName": "eslint-plugins",
      "matchDepNames": [
        "eslint-plugin-**",
        "/\/eslint-plugin/"
      ]
  }, {
      "groupName": "eslint",
      "matchDepNames": [
        "eslint",
        "eslint-plugin-n",
        "eslint-plugin-unicorn"
      ]
  }, {
      "groupName": "browserslist",
      "matchDepNames": [
        "browserslist",
        "caniuse-lite"
      ]
  }, {
      "groupName": "ua-parser-js",
      "matchDepNames": [
        "ua-parser-js"
      ]
  }, {
      "groupName": "webpack",
      "matchDepNames": ["/webpack/"]
  }, {
      "groupName": "testcontainers",
      "matchDepNames": ["/testcontainers/"]
  }, {
      "groupName": "module-api",
      "matchDepNames": ["@element-hq/element-web-module-api"]
  }],
  "pinDigests": true,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "configMigration": true,
  "dependencyDashboard": true,
  "rebaseWhen": "conflicted",
  "prConcurrentLimit": 5,
  "draftPR": true
}
